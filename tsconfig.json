{
    "ts-node": {
        "compilerOptions": {
            "target": "es6",
            "module": "commonjs"
        }
    },
    "compilerOptions": {
        "strict": true,
        "target": "es2023",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "module": "commonjs",
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "rootDir": ".",
        "outDir": "./dist/",
        "noEmitOnError": true,
        "typeRoots": ["node_modules/@types", "./custom_typing"],
        "types": ["chrome", "node"],
        "incremental": true,
        "paths": {
            "@api/*": ["./src/api/*"],
            "@static/*": ["./src/static/*"],
            "@coreUtils/*": ["./src/utils/*"],
            "@models/*": ["./src/models/*"]
        }
    },
    "include": [
        "./src/**/*",
        "./rspack.config.ts",
        "./custom_typing/**/*"
    ],
    "exclude": ["public", "./node_modules"]
}
