{
  "name": "more-boosty-remastered",
  "version": "1.4.4",
  "description": "Improved and redesigned More Boosty browser extension which improves interface and functions of crowdfunding platform Boosty.",
  "scripts": {
    "dev": "rspack --watch --mode=development",
    "prod": "npm run lint && npm run build:prod",
    "build:prod": "rspack --mode=production",
    "build:dev": "rspack --mode=development",
    "lint": "npm run eslint && npm run stylelint",
    "eslint": "eslint --ext .ts,.tsx,.js src --color --config eslint.config.mjs",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "lint:fix": "npm run eslint:fix && npm run stylelint:fix",
    "eslint:fix": "eslint --ext .ts,.tsx,.js src --color --fix",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "git add"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "git add"
    ]
  },
  "browserslist": [
    "last 1 Chrome version",
    "last 1 Firefox version"
  ],
  "dependencies": {
    "axios": "1.16.0",
    "html-template-tag": "5.0.0",
    "luxon": "3.7.2",
    "ts-enum-util": "4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@rspack/cli": "2.0.1",
    "@rspack/core": "2.0.1",
    "@rspack/dev-server": "2.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/chrome": "0.1.40",
    "@types/luxon": "3.7.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "clean-webpack-plugin": "4.0.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.2",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "sass-embedded": "1.99.0",
    "sass-loader": "16.0.7",
    "stylelint": "17.11.0",
    "stylelint-config-sass-guidelines": "13.0.0",
    "stylelint-order": "8.1.1",
    "stylelint-scss": "7.0.0",
    "ts-checker-rspack-plugin": "1.3.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "webExt": {
    "sourceDir": "dist",
    "run": {
      "startUrl": [
        "https://github.com/IvanSavoskin/more-boosty-remaster"
      ]
    }
  }
}
